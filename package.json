{
  "name": "stredoveky-festival-stropkov",
  "private": true,
  "scripts": {
    "dev": "live-server --port=5500 --open=/",
    "start": "npm run dev",
    "build": "node scripts/build-bankovy-dar-qr.mjs && node scripts/build.mjs",
    "build:qr": "node scripts/build-bankovy-dar-qr.mjs",
    "vendor:copy": "node scripts/copy-vendor.mjs",
    "prebuild": "node scripts/copy-vendor.mjs && node scripts/build-sach-bundle.mjs && node scripts/build-bankovy-dar-qr.mjs",
    "test:puzzles": "node scripts/validate-puzzles.mjs",
    "test:puzzles:soundness": "node scripts/audit-puzzle-soundness.mjs",
    "test:puzzles:alt": "node scripts/test-puzzle-alternatives.mjs",
    "test:mobile-chess": "node scripts/test-mobile-chess.mjs",
    "generated:normalize": "node normalize-generated-files.mjs",
    "postspec:gen": "npm run generated:normalize"
  },
  "devDependencies": {
    "esbuild": "^0.28.1",
    "live-server": "^1.2.2",
    "playwright": "^1.60.0"
  },
  "dependencies": {
    "@lichess-org/chessground": "^10.1.1",
    "@lostinbrittany/qr-esm": "^1.2.0",
    "bysquare": "^4.0.0",
    "chess.js": "^1.4.0"
  }
}
